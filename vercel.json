{
  "version": 2,
  "buildCommand": "npx nx build client --prod && npx nx build api --prod",
  "installCommand": "npm install",
  "env": {
    "NX_DAEMON": "false",
    "NODE_OPTIONS": "--max-old-space-size=2048"
  },
  "functions": {
    "api.js": {
      "memory": 2048,
      "maxDuration": 30,
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.js",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}