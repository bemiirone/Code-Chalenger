{
  "version": 2,
  "buildCommand": "npm run build:client && npm run build:api",
  "installCommand": "npm install",
  "outputDirectory": "dist/apps/client/browser",
  "env": {
    "NX_DAEMON": "false",
    "NODE_OPTIONS": "--max-old-space-size=2048"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api.js"
    },
    {
      "source": "/(.*)",
      "destination": "index.html"
    }
  ]
}